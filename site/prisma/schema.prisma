generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String      @id @default(cuid())
  name        String
  price       Float
  category    String
  image       String
  sku         String?
  description String?
  brand       String?
  stockQty    Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  cartItems   CartItem[]
  orderItems  OrderItem[]
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum UserStatus {
  ENABLED
  DISABLED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         UserRole   @default(CUSTOMER)
  status       UserStatus @default(ENABLED)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Cart {
  sessionId String     @id
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
}

model CartItem {
  id          Int      @id @default(autoincrement())
  cartSessionId String
  productId   String
  quantity    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cart        Cart     @relation(fields: [cartSessionId], references: [sessionId], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([cartSessionId, productId])
  @@index([cartSessionId])
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

enum PaymentProvider {
  STUB
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
}

model Order {
  id          Int        @id @default(autoincrement())
  orderNumber String     @unique
  sessionId   String
  status      OrderStatus @default(PENDING)
  customerName String?
  addressLine1 String?
  city         String?
  postalCode   String?
  deliveryMethod String?
  subtotal    Float
  tax         Float
  total       Float
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  items       OrderItem[]
  payments    Payment[]

  @@index([sessionId, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

model OrderItem {
  id         Int      @id @default(autoincrement())
  orderId    Int
  productId  String
  name       String
  price      Float
  quantity   Int

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model Payment {
  id         Int             @id @default(autoincrement())
  orderId    Int
  provider   PaymentProvider
  status     PaymentStatus
  amount     Float
  createdAt  DateTime        @default(now())

  order      Order           @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
}
