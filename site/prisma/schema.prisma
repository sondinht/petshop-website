generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String      @id @default(uuid())
  name        String
  price       Float
  category    String
  enabled     Boolean     @default(true)
  sku         String?
  description String?
  brand       String?
  stockQty    Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  cartItems   CartItem[]
  orderItems  OrderItem[]
  images      ProductImage[]
  placements  ProductPlacement[]
  collections ProductCollectionMembership[]
  variants    ProductVariant[]
  reviews     Review[]
}

model ProductVariant {
  id          String    @id @default(uuid())
  productId   String
  name        String
  price       Float
  originalPrice Float?
  stockQty    Int?
  enabled     Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]

  @@index([productId, sortOrder])
  @@index([productId, enabled, sortOrder])
}

model Review {
  id          String   @id @default(cuid())
  productId   String?
  rating      Int
  title       String?
  body        String
  authorName  String
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId, enabled, sortOrder])
  @@index([enabled, createdAt])
}

enum ProductCollectionType {
  FLASH_SALE
  BEST_SELLERS
}

model ProductCollectionMembership {
  productId   String
  collection  ProductCollectionType
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, collection])
  @@index([collection])
}

model ProductPlacement {
  productId      String
  storefrontPage String
  createdAt      DateTime @default(now())
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, storefrontPage])
  @@index([storefrontPage])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@unique([productId, url])
}

enum UserRole {
  ADMIN
  STAFF
  CUSTOMER
}

enum UserStatus {
  ENABLED
  DISABLED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         UserRole   @default(CUSTOMER)
  tokenVersion Int        @default(0)
  status       UserStatus @default(ENABLED)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Cart {
  sessionId String     @id
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
}

model CartItem {
  id            Int      @id @default(autoincrement())
  cartSessionId String
  productId     String
  productVariantId String?
  variantName   String?
  unitPrice     Float
  quantity      Int
  savedForLater Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cart          Cart     @relation(fields: [cartSessionId], references: [sessionId], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@index([cartSessionId])
  @@index([cartSessionId, productId, productVariantId])
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

enum PaymentProvider {
  STUB
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
}

model Order {
  id          Int        @id @default(autoincrement())
  orderNumber String     @unique
  sessionId   String
  status      OrderStatus @default(PENDING)
  customerName String?
  addressLine1 String?
  city         String?
  postalCode   String?
  deliveryMethod String?
  subtotal    Float
  tax         Float
  total       Float
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  items       OrderItem[]
  payments    Payment[]

  @@index([sessionId, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

model OrderItem {
  id              Int      @id @default(autoincrement())
  orderId         Int
  productId       String
  productVariantId String?
  variantName     String?
  name            String
  price           Float
  quantity        Int

  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model Payment {
  id         Int             @id @default(autoincrement())
  orderId    Int
  provider   PaymentProvider
  status     PaymentStatus
  amount     Float
  createdAt  DateTime        @default(now())

  order      Order           @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

enum FlashSaleDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model FlashSaleCampaign {
  id            String                @id @default(cuid())
  name          String
  startAt       DateTime
  endAt         DateTime
  discountType  FlashSaleDiscountType @default(PERCENTAGE)
  discountValue Float?
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([isActive, startAt, endAt])
}
